APP_NAME=StockWatch
DEBUG=false

POSTGRES_DB=stockwatch
POSTGRES_USER=stockwatch
POSTGRES_PASSWORD=secret

DATABASE_URL=postgresql+psycopg2://stockwatch:secret@db:5432/stockwatch
DATABASE_URL_ASYNC=postgresql+asyncpg://stockwatch:secret@db:5432/stockwatch

REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-to-a-very-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
